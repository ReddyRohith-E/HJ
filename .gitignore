# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Node modules
node_modules/

# Build output
dist/
dist-ssr/
build/
out/
.output/

# Vite cache
.vite/

# Temporary folders
.cache/
.parcel-cache/
/.next/
.nuxt/
/.vercel/
/.firebase/
.serverless/

# Coverage
coverage/
coverage-final.json

# Environment files
.env
.env.*.local
.env.local
.env.production.local
.env.development.local
.env.test.local

# dotenv environment variables
.envrc

# Inspector and debug logs
.nyc_output/
.eslintcache

# OS generated files
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two "+" signs
Icon

# Thumbnails
._*

# Linux
*~

# Editors and IDEs
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
out/ide_build/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.swp
.swo

# Emacs
*~
.emacs.desktop
.emacs.desktop.lock

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# Other OS / Editor files
*.orig
*.patch

# Package managers
# lockfiles should generally be committed for deterministic installs, so we do NOT ignore:
# package-lock.json
# pnpm-lock.yaml
# yarn.lock

# Optional: ignore installed binary caches
.pnp.cjs
.pnp.js

# Build artifacts from mobile/native (if present)
android/**/build/
ios/Pods/
ios/build/

# Typescript
*.tsbuildinfo

# Generated docs
docs/**

# Test outputs
junit-report.xml
test-results/

# Dependency directories for other languages (safe to ignore even if absent)
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Ruby
.bundle/
vendor/bundle/

# Go
bin/

# MacOS X Finder tags
.fseventsd

# Secrets and keys
# (Keep these ignored to avoid accidental commits)
*.pem
*.key
*.crt
secrets/
credentials/

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# End of recommended ignores
